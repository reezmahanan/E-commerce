# ============================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to backend/.env and fill in your own values.
# Do NOT put real credentials here — this file is committed to git.

# ============================================
# SERVER CONFIGURATION
# ============================================

# Express Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://127.0.0.1:5500
API_URL=http://localhost:5000

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=ecommerce
DB_SSL=false

# Database Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE=10000

# ============================================
# JWT & AUTHENTICATION
# ============================================

# JWT Secret (use a long random string - minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# OTP CONFIGURATION
# ============================================

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
OTP_TYPE=numeric
OTP_ENABLE_LOGGING=true
OTP_ENABLE_RATE_LIMITING=true
OTP_ENABLE_DATABASE=true

# ============================================
# RATE LIMITER CONFIGURATION
# ============================================

# General Rate Limiter
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100  # Default max requests per window

# Auth Rate Limiters
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_REFRESH_MAX=10
RATE_LIMIT_FORGOT_PASSWORD_MAX=3
RATE_LIMIT_OTP_VERIFY_MAX=3
RATE_LIMIT_RESET_PASSWORD_MAX=3
RATE_LIMIT_OTP_REQUEST_MAX=3
RATE_LIMIT_OTP_WINDOW_MS=300000  # 5 minutes

# API Rate Limiters
RATE_LIMIT_API_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_API_MAX=60

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis (for caching, rate limiting, sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ============================================
# AGENT LIABILITY SERVICE
# ============================================

# Agent Liability
LIABILITY_WEBHOOK_URL=
AGENT_AUTH_SECRET=your-agent-auth-secret-32-chars-min
LOG_LEVEL=info

# ============================================
# ASSEMBLYAI CONFIGURATION
# ============================================

# AssemblyAI Transcription Service
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ASSEMBLYAI_LANGUAGE_MODEL=best
ASSEMBLYAI_PUNCTUATE=true
ASSEMBLYAI_FORMAT_TEXT=true
ASSEMBLYAI_SPEAKER_LABELS=false
ASSEMBLYAI_AUTO_HIGHLIGHTS=false
ASSEMBLYAI_ENTITY_DETECTION=false
ASSEMBLYAI_LANGUAGE_CODE=en
ASSEMBLYAI_WEBHOOK_URL=
ASSEMBLYAI_WEBHOOK_AUTH=
ASSEMBLYAI_MAX_RETRIES=3
ASSEMBLYAI_INITIAL_DELAY=1000
ASSEMBLYAI_CACHE_TTL=3600
ASSEMBLYAI_ENABLE_CACHE=true

# ============================================
# COMPRESSION CONFIGURATION
# ============================================

# Response Compression
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024
COMPRESSION_MEM_LEVEL=8
COMPRESSION_CHUNK_SIZE=16384
COMPRESSION_ENABLED=true

# ============================================
# SECURITY & HELMET
# ============================================

# Helmet Security Headers
HELMET_CSP_ENABLED=true
HELMET_HSTS_ENABLED=true
HELMET_HSTS_MAX_AGE=31536000

# CORS
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500
CORS_CREDENTIALS=true

# ============================================
# LOGGING & MONITORING
# ============================================

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log

# Metrics
METRICS_ENABLED=false
METRICS_PORT=9090

# ============================================
# SESSION CONFIGURATION
# ============================================

# Session
SESSION_SECRET=your-session-secret-32-chars-min
SESSION_EXPIRY=3600000  # 1 hour in milliseconds

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# CLOUD STORAGE
# ============================================

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ============================================
# FEATURE FLAGS
# ============================================

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# ============================================
# PAYMENT GATEWAY
# ============================================

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ============================================
# EXTERNAL SERVICES
# ============================================

# External API Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ============================================
# MAINTENANCE & DEBUG
# ============================================

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently under maintenance. Please try again later.

# Debug
DEBUG=false
DEBUG_VERBOSE=false

# ============================================
# TESTING
# ============================================

# Testing
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=test-password
TEST_DB_NAME=ecommerce_test
TEST_JWT_SECRET=test-jwt-secret-32-chars-min

# ============================================
# DEPLOYMENT
# ============================================

# Deployment
DEPLOYMENT_ENV=development  # development, staging, production
ENABLE_HTTPS=false
SSL_KEY_PATH=/path/to/key.pem
SSL_CERT_PATH=/path/to/cert.pem
